{
  // Test: conal.ryan1988@gmail.com retains access to personal machines.
  // conal-pi is owned by this user, so it falls under autogroup:self.
  // tag:ireland-pi is also checked as an explicit tagged destination.
  "tests": [
    // SSH access to own machine (conal-pi is autogroup:self for this user)
    {
      "src":    "conal.ryan1988@gmail.com",
      "accept":    "conal-pi",
    },
    // SSH access via tagged machine
    {
      "src":    "conal.ryan1988@gmail.com",
      "accept":    "tag:ireland-pi",
    },
  ],
}
